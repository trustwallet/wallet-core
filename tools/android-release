#!/bin/bash
#
# Builds Android artifacts for release and uploads Kotlin docs
#
# Usage: android-release <version> [--skip-docs]
#   version    - version to build (required)
#   --skip-docs - skip building and uploading docs

set -e

source "$(dirname "$0")/library"

# Parse arguments
skip_docs=false
version=""

for arg in "$@"; do
    if [[ "$arg" == "--skip-docs" ]]; then
        skip_docs=true
    elif [[ -z "$version" ]]; then
        version="$arg"
    fi
done

version=$(wc_read_version "$version")

if [[ $(uname -s) == "Darwin" ]]; then
    BOOST_ROOT=$(brew --prefix boost)
    export BOOST_ROOT
fi

echo "Building Android $version"

export ANDROID_HOME="$HOME/Library/Android/sdk"
pushd android
./gradlew clean build assembleRelease -Pversion="$version"
popd

echo "Android build completed"

# Build and upload docs
if [[ "$skip_docs" != true ]]; then
    echo "Building docs..."
    tools/kotlin-doc

    pushd build/dokka

    filename=kdoc.zip
    echo "Upload asset $filename"
    download_url=$(wc_upload_asset "${version}" "${filename}")
    echo "download_url is $download_url"

    popd # build/dokka
fi
