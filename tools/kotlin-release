#!/bin/bash
#
# Usage: kotlin-release <version> [publish_url]
#   version     - version to publish (required)
#   publish_url - optional maven repository URL (defaults to GitHub Packages)

set -e

source $(dirname $0)/library
version=$(wc_read_version $1)
publish_url="$2"

echo "Building $version"

export ANDROID_HOME="$HOME/Library/Android/sdk"
export BOOST_ROOT=$(brew --prefix boost)

publish_url_arg=""
if [[ -n "$publish_url" ]]; then
    echo "Using custom publish URL: $publish_url"
    publish_url_arg="-PpublishUrl=$publish_url"
fi

pushd kotlin
./gradlew :wallet-core-kotlin:generateProtos
./gradlew :wallet-core-kotlin:assemble :wallet-core-kotlin:publish -Pversion="$version" $publish_url_arg
popd

echo "Kotlin build uploaded"
